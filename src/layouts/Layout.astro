---
import '../styles/global.css';

const {
  title = 'Swapnil Khalekar — AI Product Manager',
  description = 'AI Product Manager building RAG + agentic systems that ship—and scale.',
  ogImage = '/og.png',
} = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />

    <meta name="twitter:card" content="summary_large_image" />

    <link rel="preload" as="image" href="/headshot.jpg" />
  </head>
  <body class="bg-[rgb(var(--bg))] text-[rgb(var(--fg))] antialiased selection:bg-[rgba(var(--accent),0.25)] selection:text-[rgb(var(--fg))]">
    <a href="#content" class="sr-only focus:not-sr-only focus:fixed focus:left-4 focus:top-4 focus:z-50 focus:rounded-md focus:bg-[rgb(var(--card))] focus:px-3 focus:py-2 focus:text-sm focus:ring-2 focus:ring-[rgb(var(--accent))]">Skip to content</a>

    <div class="min-h-dvh">
      <div class="mx-auto w-full max-w-5xl px-5 pt-6 sm:px-8">
        <div class="flex items-center justify-end">
          <button
            id="theme-toggle"
            type="button"
            class="inline-flex items-center gap-2 rounded-md border border-[rgb(var(--border))] bg-[rgba(var(--card),0.35)] px-3 py-2 text-xs font-medium text-[rgb(var(--fg))] hover:bg-[rgba(var(--card),0.6)] focus:outline-none focus:ring-2 focus:ring-[rgb(var(--accent))]"
            aria-label="Toggle theme"
          >
            <span id="theme-icon" aria-hidden="true">◐</span>
            <span id="theme-label">Theme</span>
          </button>
        </div>
      </div>

      <main id="content" class="mx-auto w-full max-w-6xl px-5 py-10 sm:px-8 sm:py-14">
        <slot />
      </main>
      <footer class="border-t border-[rgba(var(--border),0.7)]">
        <div class="mx-auto w-full max-w-5xl px-5 py-10 text-sm text-[rgb(var(--muted))] sm:px-8">
          <div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
            <div>
              <span class="text-[rgb(var(--fg))]">Swapnil Khalekar</span> · Pune, India
            </div>
            <div class="flex gap-4">
              <a class="hover:opacity-90" href="mailto:swapnibk@gmail.com">Email</a>
              <a class="hover:opacity-90" href="https://www.linkedin.com/in/swapnil-khalekar?utm_source=share&utm_campaign=share_via&utm_content=profile&utm_medium=ios_app">LinkedIn</a>
              <a class="hover:opacity-90" href="https://github.com/interstellarswapnil-eng">GitHub</a>
            </div>
          </div>
        </div>
      </footer>
    </div>

    <script is:inline>
      (() => {
        const storageKey = 'theme';
        const root = document.documentElement;
        const btn = document.getElementById('theme-toggle');
        const icon = document.getElementById('theme-icon');
        const label = document.getElementById('theme-label');

        const systemPrefersLight = () =>
          window.matchMedia && window.matchMedia('(prefers-color-scheme: light)').matches;

        const getInitialTheme = () => {
          const saved = localStorage.getItem(storageKey);
          if (saved === 'light' || saved === 'dark') return saved;
          return systemPrefersLight() ? 'light' : 'dark';
        };

        const apply = (theme) => {
          if (theme === 'light') root.setAttribute('data-theme', 'light');
          else root.removeAttribute('data-theme');
          if (icon) icon.textContent = theme === 'light' ? '☀' : '☾';
          if (label) label.textContent = theme === 'light' ? 'Light' : 'Dark';
        };

        const current = getInitialTheme();
        apply(current);

        btn?.addEventListener('click', () => {
          const next = (root.getAttribute('data-theme') === 'light') ? 'dark' : 'light';
          localStorage.setItem(storageKey, next);
          apply(next);
        });
      })();
    </script>
  </body>
</html>
